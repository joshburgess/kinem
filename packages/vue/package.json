{
  "name": "@motif-animate/vue",
  "version": "0.0.0",
  "description": "Vue bindings for motif-animate",
  "license": "MIT",
  "author": "Josh Burgess",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshburgess/motif.git",
    "directory": "packages/vue"
  },
  "homepage": "https://github.com/joshburgess/motif#readme",
  "bugs": "https://github.com/joshburgess/motif/issues",
  "keywords": ["animation", "vue", "motion", "spring"],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rm -rf dist && rollup -c rollup.config.mjs && tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.cts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "motif-animate": "workspace:*",
    "vue": ">=3.4"
  },
  "devDependencies": {
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^15.11.7",
    "motif-animate": "workspace:*",
    "typescript": "^5.7.2",
    "vue": "^3.5.13"
  }
}
