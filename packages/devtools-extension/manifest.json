{
  "manifest_version": 3,
  "name": "Kinem DevTools",
  "version": "0.2.0",
  "description": "Inspect, scrub, and record kinem animations from a dedicated Chrome DevTools panel.",
  "minimum_chrome_version": "111",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["agent.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "permissions": ["scripting"],
  "web_accessible_resources": [
    {
      "resources": ["agent.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
