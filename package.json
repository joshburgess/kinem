{
  "name": "kinem-workspace",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "pnpm -r run clean",
    "bench": "vitest bench --run",
    "bench:watch": "vitest bench",
    "size": "node scripts/bundle-size.mjs",
    "size:check": "node scripts/bundle-size.mjs --check",
    "size:compare": "node scripts/bundle-size-compare.mjs",
    "release:dry-run": "pnpm -r publish --access public --no-git-checks --dry-run",
    "release": "pnpm -r publish --access public --no-git-checks"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@swc/core": "^1.15.30",
    "@types/node": "^22.19.17",
    "esbuild": "^0.28.0",
    "fast-check": "^4.7.0",
    "rollup": "^4.60.2",
    "rollup-plugin-swc3": "^0.12.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
