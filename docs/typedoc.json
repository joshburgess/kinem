    "../packages/core/src/interpolate/registry.ts",
    "../packages/core/src/render/canvas.ts",
    "../packages/core/src/render/webgl.ts",
    "../packages/core/src/render/svg.ts",
    "../packages/core/src/render/strategy.ts",
    "../packages/core/src/render/waapi.ts",
